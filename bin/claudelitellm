#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

require_command() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "ERROR: Required command not found: $cmd"
    exit 1
  fi
}

cleanup_dir() {
  local path="$1"
  python3 - <<'PY' "$path"
import pathlib
import shutil
import sys

path = pathlib.Path(sys.argv[1])
if path.exists():
    shutil.rmtree(path, ignore_errors=True)
    if path.exists():
        print(f"WARN: Failed to fully remove temporary directory: {path}", file=sys.stderr)
PY
}

merge_enabled_plugins_into_home_settings() {
  local canonical_settings_path="$1"
  local merged_settings_path="$2"

  python3 - <<'PY' "$canonical_settings_path" "$merged_settings_path"
import json
import pathlib
import sys
import tempfile

canonical_path = pathlib.Path(sys.argv[1])
merged_path = pathlib.Path(sys.argv[2])

if not merged_path.exists():
    raise SystemExit(0)

try:
    merged_settings = json.loads(merged_path.read_text())
except Exception as exc:
    print(f"WARN: Failed to read merged settings for plugin persistence: {exc}", file=sys.stderr)
    raise SystemExit(0)

try:
    canonical_settings = json.loads(canonical_path.read_text()) if canonical_path.exists() else {}
except Exception as exc:
    print(f"WARN: Failed to read canonical settings for plugin persistence: {exc}", file=sys.stderr)
    raise SystemExit(0)

canonical_plugins = canonical_settings.get("enabledPlugins")
if not isinstance(canonical_plugins, dict):
    canonical_plugins = {}

merged_plugins = merged_settings.get("enabledPlugins")
if not isinstance(merged_plugins, dict):
    merged_plugins = {}

normalized_plugins = dict(canonical_plugins)
for key, value in merged_plugins.items():
    normalized_plugins[key] = value
    if key.endswith("@claude-plugins-official"):
        normalized_plugins[key.rsplit("@", 1)[0]] = value

if canonical_settings.get("enabledPlugins") == normalized_plugins:
    raise SystemExit(0)

canonical_settings["enabledPlugins"] = normalized_plugins
canonical_path.parent.mkdir(parents=True, exist_ok=True)
with tempfile.NamedTemporaryFile("w", dir=canonical_path.parent, delete=False) as handle:
    temp_path = pathlib.Path(handle.name)
    json.dump(canonical_settings, handle, indent=2)
    handle.write("\n")

temp_path.replace(canonical_path)
PY
}

merge_global_claude_state_into_home() {
  local canonical_state_path="$1"
  local merged_state_path="$2"

  python3 - <<'PY' "$canonical_state_path" "$merged_state_path"
import json
import pathlib
import sys
import tempfile

canonical_path = pathlib.Path(sys.argv[1])
merged_path = pathlib.Path(sys.argv[2])

if not merged_path.exists():
    raise SystemExit(0)

try:
    merged_state = json.loads(merged_path.read_text())
except Exception as exc:
    print(f"WARN: Failed to read merged global Claude state for plugin persistence: {exc}", file=sys.stderr)
    raise SystemExit(0)

try:
    canonical_state = json.loads(canonical_path.read_text()) if canonical_path.exists() else {}
except Exception as exc:
    print(f"WARN: Failed to read canonical global Claude state for plugin persistence: {exc}", file=sys.stderr)
    raise SystemExit(0)

plugin_related_keys = {
    "officialMarketplaceAutoInstallAttempted",
    "officialMarketplaceAutoInstalled",
}

updated = False
for key in plugin_related_keys:
    if key in merged_state and canonical_state.get(key) != merged_state[key]:
        canonical_state[key] = merged_state[key]
        updated = True

if not updated:
    raise SystemExit(0)

canonical_path.parent.mkdir(parents=True, exist_ok=True)
with tempfile.NamedTemporaryFile("w", dir=canonical_path.parent, delete=False) as handle:
    temp_path = pathlib.Path(handle.name)
    json.dump(canonical_state, handle, indent=2)
    handle.write("\n")

temp_path.replace(canonical_path)
PY
}

port_listen_pids() {
  lsof -tiTCP:"$1" -sTCP:LISTEN 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//'
}

filter_proxy_matches_expected() {
  local code
  code="$(curl -sS -o "$FILTER_MODELS_OUTPUT" -w "%{http_code}" \
    -H "Authorization: Bearer $LITELLM_KEY" \
    "$FILTER_URL/v1/models" || true)"
  [[ "$code" == "200" || "$code" == "401" || "$code" == "403" ]]
}

cleanup() {
  if [[ -n "${CANONICAL_SETTINGS_PATH:-}" && -n "${MERGED_CLAUDE_CONFIG_DIR:-}" ]]; then
    merge_enabled_plugins_into_home_settings "$CANONICAL_SETTINGS_PATH" "$MERGED_CLAUDE_CONFIG_DIR/settings.json"
  fi
  if [[ -n "${CANONICAL_CLAUDE_STATE_PATH:-}" && -n "${CLEAN_HOME:-}" ]]; then
    merge_global_claude_state_into_home "$CANONICAL_CLAUDE_STATE_PATH" "$CLEAN_HOME/.claude.json"
  fi
  if [[ -n "${FILTER_PID:-}" ]]; then
    kill "$FILTER_PID" 2>/dev/null || true
    wait "$FILTER_PID" 2>/dev/null || true
  fi
  if [[ -n "${LITELLM_PID:-}" ]]; then
    kill "$LITELLM_PID" 2>/dev/null || true
    wait "$LITELLM_PID" 2>/dev/null || true
  fi
  if [[ -n "${CLEAN_HOME:-}" && -d "${CLEAN_HOME:-}" ]]; then
    cleanup_dir "$CLEAN_HOME"
  fi
}

trap cleanup EXIT

require_command claude
require_command python3
require_command curl
require_command lsof

require_python_module() {
  local module="$1"
  if ! python3 -c "import ${module}" >/dev/null 2>&1; then
    echo "ERROR: Required Python module not found: ${module}"
    echo "Install it with: python3 -m pip install ${module}"
    exit 1
  fi
}

require_python_module httpx

REAL_CLAUDE_BIN="$(command -v claude)"

append_unique_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0

  local existing
  for existing in "${CONFIG_SOURCE_DIRS[@]:-}"; do
    [[ "$existing" == "$dir" ]] && return 0
  done

  CONFIG_SOURCE_DIRS+=("$dir")
}

collect_parent_config_dirs() {
  local dir="$1"
  local chain=()

  while [[ "$dir" != "/" ]]; do
    chain+=("$dir")
    dir="$(dirname "$dir")"
  done
  chain+=("/")

  local idx
  for (( idx=${#chain[@]}-1; idx>=0; idx-- )); do
    append_unique_dir "${chain[$idx]}/.claude"
    append_unique_dir "${chain[$idx]}/.codex"
  done
}

overlay_tree() {
  local src="$1"
  local dst="$2"

  [[ -d "$src" ]] || return 0
  mkdir -p "$dst"
  chmod -R u+w "$dst" 2>/dev/null || true
  ditto "$src" "$dst"
}

HOME_CLAUDE_CONFIG_DIR="$HOME/.claude"
HOME_CODEX_CONFIG_DIR="$HOME/.codex"
REPO_CLAUDE_CONFIG_DIR="$REPO_ROOT/.claude"
REPO_CODEX_CONFIG_DIR="$REPO_ROOT/.codex"
CANONICAL_SETTINGS_PATH="$HOME_CLAUDE_CONFIG_DIR/settings.json"
CANONICAL_CLAUDE_STATE_PATH="$HOME/.claude.json"
HOME_MCP_CONFIG_PATH="$HOME_CLAUDE_CONFIG_DIR/claudelitellmmcps.json"
REPO_MCP_CONFIG_PATH="$REPO_CLAUDE_CONFIG_DIR/claudelitellmmcps.json"
LOCAL_LITELLM_CONFIG_PATH="$REPO_ROOT/config/litellm.config.yaml"
LOCAL_LITELLM_ENV_PATH="$REPO_ROOT/config/litellm.env"
REAL_LITELLM_URL="${REAL_LITELLM_URL:-http://127.0.0.1:4000}"
FILTER_PORT="${FILTER_PORT:-4001}"
FILTER_URL="http://127.0.0.1:${FILTER_PORT}"
MODEL="${ANTHROPIC_MODEL:-gpt-5.4}"
LOCAL_LITELLM_LOG_PATH="${LOCAL_LITELLM_LOG_PATH:-${TMPDIR:-/tmp}/litellm-local.log}"

FILTER_SCRIPT_PATH="${FILTER_SCRIPT_PATH:-${TMPDIR:-/tmp}/litellm_strip_output_config_proxy.py}"
FILTER_LOG_PATH="${FILTER_LOG_PATH:-${TMPDIR:-/tmp}/litellm-filter.log}"
LITELLM_MODELS_OUTPUT="${LITELLM_MODELS_OUTPUT:-${TMPDIR:-/tmp}/litellm_models.json}"
FILTER_MODELS_OUTPUT="${FILTER_MODELS_OUTPUT:-${TMPDIR:-/tmp}/litellm_filter_models.json}"
FILTER_UPSTREAM_TIMEOUT="${FILTER_UPSTREAM_TIMEOUT:-600}"
FILTER_UPSTREAM_CONNECT_TIMEOUT="${FILTER_UPSTREAM_CONNECT_TIMEOUT:-10}"
FILTER_UPSTREAM_RETRIES="${FILTER_UPSTREAM_RETRIES:-2}"
FILTER_UPSTREAM_RETRY_BACKOFF="${FILTER_UPSTREAM_RETRY_BACKOFF:-0.5}"
FILTER_MAX_CONNECTIONS="${FILTER_MAX_CONNECTIONS:-100}"
FILTER_MAX_KEEPALIVE_CONNECTIONS="${FILTER_MAX_KEEPALIVE_CONNECTIONS:-20}"

can_autostart_local_litellm() {
  [[ "$REAL_LITELLM_URL" == "http://127.0.0.1:4000" || "$REAL_LITELLM_URL" == "http://localhost:4000" ]]
}

load_local_litellm_env() {
  [[ -f "$LOCAL_LITELLM_ENV_PATH" ]] || return 1
  set -a
  # shellcheck disable=SC1090
  source "$LOCAL_LITELLM_ENV_PATH"
  set +a
}

start_local_litellm() {
  [[ -f "$LOCAL_LITELLM_CONFIG_PATH" ]] || return 1
  [[ -f "$LOCAL_LITELLM_ENV_PATH" ]] || return 1
  require_command litellm

  echo "LiteLLM is down at $REAL_LITELLM_URL."
  echo "Starting the repo-local LiteLLM on port 4000..."

  load_local_litellm_env
  LITELLM_KEY="${LITELLM_KEY:-${LITELLM_API_KEY:-${LITELLM_MASTER_KEY:-}}}"

  : >"$LOCAL_LITELLM_LOG_PATH"
  (
    cd "$REPO_ROOT"
    litellm --host 127.0.0.1 --port 4000 --config "$LOCAL_LITELLM_CONFIG_PATH"
  ) >"$LOCAL_LITELLM_LOG_PATH" 2>&1 &
  LITELLM_PID="$!"

  local attempt
  for attempt in {1..20}; do
    local code
    code="$(curl -sS -o "$LITELLM_MODELS_OUTPUT" -w "%{http_code}" "$REAL_LITELLM_URL/v1/models" || true)"
    if [[ "$code" == "200" || "$code" == "401" || "$code" == "403" ]]; then
      return 0
    fi
    if ! kill -0 "$LITELLM_PID" 2>/dev/null; then
      break
    fi
    sleep 1
  done

  echo "ERROR: Local LiteLLM did not start correctly."
  echo "Log:"
  cat "$LOCAL_LITELLM_LOG_PATH"
  exit 1
}

materialize_mcp_config() {
  local src="$1"
  local dst="$2"

  [[ -f "$src" ]] || return 1
  mkdir -p "$(dirname "$dst")"
  cp -fL "$src" "$dst"
}

echo "=== Claude Code → filter proxy → existing LiteLLM → Azure ${MODEL} ==="
echo "Real LiteLLM: $REAL_LITELLM_URL"
echo "Filter URL:   $FILTER_URL"
echo "Model:        $MODEL"
echo

echo "Checking existing LiteLLM..."
HTTP_CODE="$(curl -sS -o "$LITELLM_MODELS_OUTPUT" -w "%{http_code}" "$REAL_LITELLM_URL/v1/models" || true)"

if [[ "$HTTP_CODE" == "000" ]] && can_autostart_local_litellm; then
  start_local_litellm
  HTTP_CODE="$(curl -sS -o "$LITELLM_MODELS_OUTPUT" -w "%{http_code}" "$REAL_LITELLM_URL/v1/models" || true)"
fi

if [[ "$HTTP_CODE" == "401" || "$HTTP_CODE" == "403" ]]; then
  LITELLM_KEY="${LITELLM_KEY:-${LITELLM_API_KEY:-}}"
  if [[ -z "$LITELLM_KEY" ]]; then
    echo "LiteLLM requires a key."
    read -r -s -p "Paste your LiteLLM key: " LITELLM_KEY
    echo
  fi
  HTTP_CODE="$(curl -sS -o "$LITELLM_MODELS_OUTPUT" -w "%{http_code}" \
    -H "Authorization: Bearer $LITELLM_KEY" \
    "$REAL_LITELLM_URL/v1/models" || true)"
else
  LITELLM_KEY="${LITELLM_KEY:-${LITELLM_API_KEY:-sk-litellm-local}}"
fi

if [[ "$HTTP_CODE" != "200" ]]; then
  echo "ERROR: Existing LiteLLM is not reachable or did not accept auth."
  echo "HTTP status: $HTTP_CODE"
  echo "Expected: $REAL_LITELLM_URL/v1/models"
  exit 1
fi

echo
echo "Confirmed LiteLLM is reachable."
echo

EXISTING_FILTER_PIDS="$(port_listen_pids "$FILTER_PORT")"
if [[ -n "$EXISTING_FILTER_PIDS" ]]; then
  echo "Found existing listener on port ${FILTER_PORT}: ${EXISTING_FILTER_PIDS}"
  if filter_proxy_matches_expected; then
    echo "Reusing the existing filter proxy on port ${FILTER_PORT}."
    FILTER_PID=""
  else
    echo "ERROR: Port ${FILTER_PORT} is already occupied by another process and the listener did not answer like the expected filter proxy."
    lsof -nP -iTCP:"$FILTER_PORT" -sTCP:LISTEN || true
    exit 1
  fi
else
  echo "Stopping any old filter proxy on port ${FILTER_PORT}..."

  wait_for_filter_port_release() {
    local attempt
    for attempt in {1..20}; do
      if ! lsof -tiTCP:"$FILTER_PORT" -sTCP:LISTEN >/dev/null 2>&1; then
        return 0
      fi
      sleep 0.25
    done

    return 1
  }

  if ! wait_for_filter_port_release; then
    echo "ERROR: Port ${FILTER_PORT} is still busy after stopping the old filter proxy."
    lsof -nP -iTCP:"$FILTER_PORT" -sTCP:LISTEN || true
    exit 1
  fi

  cat > "$FILTER_SCRIPT_PATH" <<'PY'
import http.server
import json
import os
import random
import socket
import socketserver
import sys
import time

import httpx

TARGET = os.environ.get("REAL_LITELLM_URL", "http://127.0.0.1:4000").rstrip("/")
PORT = int(os.environ.get("FILTER_PORT", "4001"))
BIND_HOST = os.environ.get("FILTER_BIND_HOST", "127.0.0.1")
ALLOWED_HOSTS = {
    host.strip()
    for host in os.environ.get("FILTER_ALLOWED_HOSTS", f"127.0.0.1,localhost,{socket.gethostname()}").split(",")
    if host.strip()
}
CONNECT_TIMEOUT = float(os.environ.get("FILTER_UPSTREAM_CONNECT_TIMEOUT", "10"))
UPSTREAM_TIMEOUT = float(os.environ.get("FILTER_UPSTREAM_TIMEOUT", "600"))
UPSTREAM_RETRIES = max(0, int(os.environ.get("FILTER_UPSTREAM_RETRIES", "2")))
RETRY_BACKOFF = max(0.0, float(os.environ.get("FILTER_UPSTREAM_RETRY_BACKOFF", "0.5")))
MAX_CONNECTIONS = max(1, int(os.environ.get("FILTER_MAX_CONNECTIONS", "100")))
MAX_KEEPALIVE_CONNECTIONS = max(1, int(os.environ.get("FILTER_MAX_KEEPALIVE_CONNECTIONS", "20")))
RETRIABLE_STATUS_CODES = {408, 425, 429, 500, 502, 503, 504}

DROP_KEYS = {
    "output_config",
}

def strip_keys(obj):
    if isinstance(obj, dict):
        return {k: strip_keys(v) for k, v in obj.items() if k not in DROP_KEYS}
    if isinstance(obj, list):
        return [strip_keys(x) for x in obj]
    return obj

CLIENT = httpx.Client(
    timeout=httpx.Timeout(connect=CONNECT_TIMEOUT, read=UPSTREAM_TIMEOUT, write=UPSTREAM_TIMEOUT, pool=CONNECT_TIMEOUT),
    limits=httpx.Limits(max_connections=MAX_CONNECTIONS, max_keepalive_connections=MAX_KEEPALIVE_CONNECTIONS),
    follow_redirects=False,
    http2=False,
)

def should_retry(method, response=None, error=None):
    if method.upper() not in {"GET", "HEAD", "OPTIONS"}:
        return False
    if error is not None:
        return isinstance(error, (httpx.ConnectError, httpx.ReadTimeout, httpx.WriteTimeout, httpx.RemoteProtocolError, httpx.PoolTimeout))
    return response is not None and response.status_code in RETRIABLE_STATUS_CODES

def retry_delay(attempt):
    return RETRY_BACKOFF * (2 ** attempt) + random.uniform(0.0, 0.1)

class Handler(http.server.BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def address_allowed(self):
        host = self.headers.get("Host", "")
        host = host.split(":", 1)[0].strip().lower()
        if not host:
            return True
        return host in {allowed.lower() for allowed in ALLOWED_HOSTS}

    def reject_host(self):
        payload = json.dumps({"error": "forbidden host header"}).encode()
        self.send_response(403)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def do_GET(self):
        self.forward()

    def do_POST(self):
        self.forward()

    def do_OPTIONS(self):
        self.forward()

    def forward(self):
        if not self.address_allowed():
            self.reject_host()
            return

        length = int(self.headers.get("content-length", "0") or "0")
        body = self.rfile.read(length) if length else b""

        if body and self.headers.get("content-type", "").startswith("application/json"):
            try:
                data = json.loads(body.decode("utf-8"))
                data = strip_keys(data)
                body = json.dumps(data).encode("utf-8")
            except Exception:
                pass

        url = TARGET + self.path

        headers = {}
        for k, v in self.headers.items():
            lk = k.lower()
            if lk in {"host", "content-length", "connection", "accept-encoding"}:
                continue
            headers[k] = v

        headers["Content-Length"] = str(len(body))

        response = None
        last_error = None
        for attempt in range(UPSTREAM_RETRIES + 1):
            try:
                response = CLIENT.request(
                    self.command,
                    url,
                    content=body if self.command not in {"GET", "HEAD"} else None,
                    headers=headers,
                )
                if should_retry(self.command, response=response) and attempt < UPSTREAM_RETRIES:
                    response.close()
                    time.sleep(retry_delay(attempt))
                    continue
                break
            except httpx.HTTPError as error:
                last_error = error
                if should_retry(self.command, error=error) and attempt < UPSTREAM_RETRIES:
                    time.sleep(retry_delay(attempt))
                    continue
                payload = json.dumps({"error": str(error)}).encode()
                self.send_response(502)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(payload)))
                self.end_headers()
                self.wfile.write(payload)
                return

        if response is None:
            payload = json.dumps({"error": str(last_error or "unknown upstream error")}).encode()
            self.send_response(502)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        payload = response.content
        self.send_response(response.status_code)
        for k, v in response.headers.items():
            lk = k.lower()
            if lk in {"transfer-encoding", "connection", "content-encoding"}:
                continue
            self.send_header(k, v)
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)
        response.close()

    def log_message(self, fmt, *args):
        sys.stderr.write("[filter] " + fmt % args + "\n")

class TightLocalTCPServer(socketserver.ThreadingTCPServer):
    allow_reuse_address = True

with TightLocalTCPServer((BIND_HOST, PORT), Handler) as httpd:
    print(
        f"Filtering proxy listening on http://{BIND_HOST}:{PORT} → {TARGET} "
        f"(allowed hosts: {', '.join(sorted(ALLOWED_HOSTS))}; retries: {UPSTREAM_RETRIES}; max_connections: {MAX_CONNECTIONS})",
        flush=True,
    )
    httpd.serve_forever()
PY

  REAL_LITELLM_URL="$REAL_LITELLM_URL" FILTER_PORT="$FILTER_PORT" \
  FILTER_UPSTREAM_TIMEOUT="$FILTER_UPSTREAM_TIMEOUT" \
  FILTER_UPSTREAM_CONNECT_TIMEOUT="$FILTER_UPSTREAM_CONNECT_TIMEOUT" \
  FILTER_UPSTREAM_RETRIES="$FILTER_UPSTREAM_RETRIES" \
  FILTER_UPSTREAM_RETRY_BACKOFF="$FILTER_UPSTREAM_RETRY_BACKOFF" \
  FILTER_MAX_CONNECTIONS="$FILTER_MAX_CONNECTIONS" \
  FILTER_MAX_KEEPALIVE_CONNECTIONS="$FILTER_MAX_KEEPALIVE_CONNECTIONS" \
    python3 "$FILTER_SCRIPT_PATH" > "$FILTER_LOG_PATH" 2>&1 &
fi

wait_for_filter_proxy() {
  local attempt
  for attempt in {1..20}; do
    if ! kill -0 "$FILTER_PID" 2>/dev/null; then
      return 1
    fi

    local code
    code="$(curl -sS -o "$FILTER_MODELS_OUTPUT" -w "%{http_code}" \
      -H "Authorization: Bearer $LITELLM_KEY" \
      "$FILTER_URL/v1/models" || true)"
    if [[ "$code" == "200" || "$code" == "401" || "$code" == "403" ]]; then
      return 0
    fi

    sleep 1
  done

  return 1
}

if [[ -z "${FILTER_PID:-}" ]]; then
  echo "Filter proxy is already running. Reusing the existing listener."
  echo
else
  if ! wait_for_filter_proxy; then
    echo "ERROR: Filter proxy did not start correctly."
    echo "Log:"
    cat "$FILTER_LOG_PATH"
    kill "$FILTER_PID" 2>/dev/null || true
    exit 1
  fi

  echo "Filter proxy is running. It strips output_config before forwarding to LiteLLM."
  echo
fi

CLEAN_HOME="$(mktemp -d "${TMPDIR:-/tmp}/claude-clean-home.XXXXXX")"
mkdir -p "$CLEAN_HOME/.local/bin"
ln -sf "$REAL_CLAUDE_BIN" "$CLEAN_HOME/.local/bin/claude"
MERGED_CLAUDE_CONFIG_DIR="$CLEAN_HOME/.claude"
MERGED_CODEX_CONFIG_DIR="$CLEAN_HOME/.codex"
MERGED_MCP_CONFIG_PATH="$MERGED_CLAUDE_CONFIG_DIR/claudelitellmmcps.json"
CONFIG_SOURCE_DIRS=()

append_unique_dir "$HOME_CLAUDE_CONFIG_DIR"
append_unique_dir "$HOME_CODEX_CONFIG_DIR"
append_unique_dir "$REPO_CLAUDE_CONFIG_DIR"
append_unique_dir "$REPO_CODEX_CONFIG_DIR"
collect_parent_config_dirs "$PWD"

for source_dir in "${CONFIG_SOURCE_DIRS[@]}"; do
  case "$(basename "$source_dir")" in
    .claude)
      overlay_tree "$source_dir" "$MERGED_CLAUDE_CONFIG_DIR"
      ;;
    .codex)
      overlay_tree "$source_dir" "$MERGED_CODEX_CONFIG_DIR"
      ;;
  esac
done

if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
  overlay_tree "$CLAUDE_CONFIG_DIR" "$MERGED_CLAUDE_CONFIG_DIR"
fi

if [[ -f "$MERGED_CLAUDE_CONFIG_DIR/settings.json" ]]; then
  python3 - <<'PY' "$MERGED_CLAUDE_CONFIG_DIR/settings.json"
import json
import pathlib
import sys

settings_path = pathlib.Path(sys.argv[1])
settings = json.loads(settings_path.read_text())
settings.pop("hooks", None)
settings_path.write_text(json.dumps(settings, indent=2) + "\n")
PY
fi

CLAUDE_CONFIG_DIR="$MERGED_CLAUDE_CONFIG_DIR"

MCP_CONFIG_SOURCE=""

if [[ -n "${MCP_CONFIG_PATH:-}" ]]; then
  RESOLVED_MCP_CONFIG_PATH="$MCP_CONFIG_PATH"
  MCP_CONFIG_SOURCE="$MCP_CONFIG_PATH"
elif materialize_mcp_config "$HOME_MCP_CONFIG_PATH" "$MERGED_MCP_CONFIG_PATH"; then
  RESOLVED_MCP_CONFIG_PATH="$MERGED_MCP_CONFIG_PATH"
  MCP_CONFIG_SOURCE="$HOME_MCP_CONFIG_PATH"
elif materialize_mcp_config "$REPO_MCP_CONFIG_PATH" "$MERGED_MCP_CONFIG_PATH"; then
  RESOLVED_MCP_CONFIG_PATH="$MERGED_MCP_CONFIG_PATH"
  MCP_CONFIG_SOURCE="$REPO_MCP_CONFIG_PATH"
elif [[ -f "$MERGED_MCP_CONFIG_PATH" ]]; then
  RESOLVED_MCP_CONFIG_PATH="$MERGED_MCP_CONFIG_PATH"
  MCP_CONFIG_SOURCE="$MERGED_MCP_CONFIG_PATH"
else
  RESOLVED_MCP_CONFIG_PATH=""
fi

echo "Merged config sources:"
for source_dir in "${CONFIG_SOURCE_DIRS[@]}"; do
  echo "  - $source_dir"
done
if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
  echo "Merged .claude target: $CLAUDE_CONFIG_DIR"
fi
if [[ -d "$MERGED_CODEX_CONFIG_DIR" ]]; then
  echo "Merged .codex target:  $MERGED_CODEX_CONFIG_DIR"
fi
if [[ -n "${MCP_CONFIG_PATH:-}" ]]; then
  echo "MCP config override:  $MCP_CONFIG_PATH"
elif [[ -n "$MCP_CONFIG_SOURCE" ]]; then
  echo "MCP config source:    $MCP_CONFIG_SOURCE"
fi
echo

CLAUDE_ARGS=(--model "$MODEL")

if [[ -n "$RESOLVED_MCP_CONFIG_PATH" && -f "$RESOLVED_MCP_CONFIG_PATH" ]]; then
  CLAUDE_ARGS=(--mcp-config "$RESOLVED_MCP_CONFIG_PATH" "${CLAUDE_ARGS[@]}")
else
  echo "No MCP config found in merged .claude directory. Continuing without --mcp-config."
  echo
fi

echo "Launching Claude Code in clean HOME so it does not use your real Claude login."
echo "Model: $MODEL"
echo

CLAUDE_BIN_ARGS=()
if [[ $# -gt 0 ]]; then
  CLAUDE_BIN_ARGS=("$@")
fi

if [[ -n "${CLAUDE_CODE_CHILD_SESSION:-}" || -n "${CLAUDECODE:-}" ]]; then
  echo "Detected nested Claude session environment. Launching child Claude without inherited print-mode session state."
fi

env -i \
  HOME="$CLEAN_HOME" \
  USER="${USER:-claw}" \
  LOGNAME="${LOGNAME:-${USER:-claw}}" \
  SHELL="${SHELL:-/bin/zsh}" \
  TERM="${TERM:-xterm-256color}" \
  PATH="$CLEAN_HOME/.local/bin:$PATH" \
  PWD="$PWD" \
  TMPDIR="${TMPDIR:-/tmp}" \
  CODEX_HOME="$MERGED_CODEX_CONFIG_DIR" \
  GH_CONFIG_DIR="${GH_CONFIG_DIR:-$HOME/.config/gh}" \
  CLAUDE_CONFIG_DIR="$CLAUDE_CONFIG_DIR" \
  ANTHROPIC_BASE_URL="$FILTER_URL" \
  ANTHROPIC_AUTH_TOKEN="$LITELLM_KEY" \
  ANTHROPIC_MODEL="$MODEL" \
  ANTHROPIC_SMALL_FAST_MODEL="$MODEL" \
  CLAUDECODE= \
  CLAUDE_CODE_CHILD_SESSION= \
  CLAUDE_CODE_SESSION_ID= \
  CLAUDE_CODE_ENTRYPOINT= \
  CLAUDE_CODE_EXECPATH= \
  claude "${CLAUDE_ARGS[@]}" ${CLAUDE_BIN_ARGS[@]+"${CLAUDE_BIN_ARGS[@]}"}
